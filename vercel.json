{
  "version": 2,
  "builds": [
    {
      "src": "manzilproject/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12",
        "buildCommand": "python manage.py collectstatic --no-input --settings=manzilproject.settings_production"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "manzilproject/wsgi.py"
    }
  ]
}
